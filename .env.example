# EVA_RUN_URL — address of the running eva-run instance
EVA_RUN_URL=http://localhost:3000

# DATABASE_URL — Postgres connection string (same DB as eva-run)
DATABASE_URL=postgresql://user:password@localhost:5432/eva

# PORT — port for the API server (default: 3001)
PORT=3001

# WEB_ORIGIN — allowed CORS origin for the frontend (default: http://localhost:5173)
WEB_ORIGIN=http://localhost:5173
